# ── App ─────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3001
APP_NAME=yuan-automotive-backend
# No global /api prefix and no version segment in route paths — the Next.js FE
# registers bare paths (see FE lib/endpoint.ts). Keep this empty unless the FE base URL changes.
GLOBAL_PREFIX=

# ── CORS (comma separated, locked to FE origins) ────
CORS_ORIGINS=https://automotive.yuandewatatimur.com,http://localhost:3000

# ── Database (MySQL 8) ──────────────────────────────
# Local dev connects to VPS MySQL via SSH tunnel:
#   ssh -L 3307:localhost:3306 user@vps
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USERNAME=yuan
DB_PASSWORD=changeme
DB_DATABASE=yuan_automotive
DB_CONNECTION_LIMIT=10

# ── JWT ─────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-another-strong-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Media storage ───────────────────────────────────
# MEDIA_STORAGE: local | cloudinary
MEDIA_STORAGE=local
MEDIA_UPLOAD_DIR=./uploads
MEDIA_PUBLIC_BASE=https://automotive.yuandewatatimur.com/media
MEDIA_MAX_SIZE_MB=10

# ── Cloudinary (required only when MEDIA_STORAGE=cloudinary) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=yuan-automotive

# ── On-demand ISR revalidation (BE → FE) ────────────
# REVALIDATE_SECRET MUST be identical to the FE env value.
FRONTEND_URL=https://automotive.yuandewatatimur.com
REVALIDATE_SECRET=shared-secret-with-frontend
REVALIDATE_TIMEOUT_MS=3000

# ── WhatsApp notifications ──────────────────────────
WA_ENABLED=false
WA_API_URL=
WA_API_TOKEN=
WA_ADMIN_NUMBER=

# ── Throttler ───────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120
THROTTLE_PUBLIC_LIMIT=10

# ── Seed admin (used by seed script only) ───────────
SEED_ADMIN_EMAIL=admin@yuandewatatimur.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_NAME=Super Admin
